# Порт API на хосте (внутри контейнера всегда 8080)
API_PORT=8080

# Параметры генерации превью
PREVIEW_WIDTH=640
PREVIEW_TIMEOUT=10
PREVIEW_NET_CONCURRENCY=20
PREVIEW_PAGE_CONCURRENCY=4
PREVIEW_JPEG_QUALITY=90
PREVIEW_VIEWPORT_WIDTH=1280
PREVIEW_VIEWPORT_HEIGHT=720

# Headless-режим Chromium: "new" или пустая строка для старого
PREVIEW_HEADLESS_MODE=new

# Префикс для коротких ID видео (если в items приходит не URL)
PREVIEW_PLAYER_PREFIX=https://runtime.video.cloud.yandex.net/player/video/

# Логирование
LOG_LEVEL=INFO
